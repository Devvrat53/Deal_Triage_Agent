# Copy this file to `.env` and fill in your own values. NEVER commit the real .env.

# --- Azure OpenAI (Microsoft Agent Framework) ---
# Endpoint ends in /openai/v1/ — passed as base_url so the SDK picks the api-version.
AZURE_OPENAI_API_KEY="your-azure-openai-key"
AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/openai/v1/"
AZURE_OPENAI_CHAT_DEPLOYMENT="gpt-5.4-mini"
AZURE_OPENAI_EMBED_DEPLOYMENT="text-embedding-ada-002"

# --- Azure AI Search (mandate vector store) ---
AZURE_SEARCH_ENDPOINT="https://<your-search>.search.windows.net"
AZURE_SEARCH_API_KEY="your-azure-search-key"
AZURE_SEARCH_INDEX="northbridge-mandate"

# --- Azure Cosmos DB (deal-pipeline system of record) ---
AZURE_COSMOS_ENDPOINT="https://<your-cosmos>.documents.azure.com:443/"
AZURE_COSMOS_KEY="your-cosmos-primary-key"
# Optional overrides (defaults shown):
# AZURE_COSMOS_DATABASE="northbridge"
# AZURE_COSMOS_CONTAINER="deals"

# --- Kept for backward-compatibility with earlier scripts ---
OPENAI_API_KEY="your-azure-openai-key"
OPENAI_BASE_URL="https://<your-resource>.openai.azure.com/"

# --- Optional: shared-password gate for a public deployment ---
# If set, the app requires this password before anything renders. Unset = open (local dev).
# APP_PASSWORD="pick-a-shared-password"
